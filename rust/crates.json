{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Enable crate updates in the dependency dashboard",
  "packageRules": [
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": ["*"],
      "dependencyDashboardApproval": true,
      "rangeStrategy": "bump"
    },
    {
      "matchDatasources": ["crate"],
      "matchCurrentValue": "/^=/",
      "enabled": false
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": ["schemars"],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    },
    {
      "matchDatasources": ["crate"],
      "matchCurrentValue": "/^\\d+(\\.\\d+)?$/",
      "rangeStrategy": "update-lockfile"
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "dropshot-api-manager",
        "dropshot-api-manager-types"
      ],
      "groupName": "dropshot-api-manager"
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": ["progenitor", "progenitor-client"],
      "groupName": "progenitor"
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": ["rand", "rand_core", "rand_distr", "rand_seeder"],
      "groupName": "rand"
    },
    {
      "matchSourceUrls": ["https://github.com/oxidecomputer/v-api"],
      "groupName": "v-api"
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": ["/^v-api/", "/^v-cli/", "/^v-model$/"],
      "groupName": "v-api"
    },
    {
      "matchDatasources": ["crate"],
      "matchPackageNames": [
        "reqwest",
        "reqwest-tracing",
        "reqwest-retry",
        "reqwest-middleware"
      ],
      "groupName": "reqwest"
    }
  ]
}
